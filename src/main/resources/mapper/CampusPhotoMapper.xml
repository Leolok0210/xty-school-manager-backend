<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaotiyun.school.manager.dao.CampusPhotoDao">

    <select id="findBySchoolId" resultType="com.xiaotiyun.school.manager.model.entity.CampusPhotoEntity">
        SELECT * FROM campus_photo WHERE school_id = #{schoolId} AND deleted = 0 ORDER BY create_time DESC
    </select>

</mapper>
