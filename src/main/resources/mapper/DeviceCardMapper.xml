<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaotiyun.school.manager.dao.DeviceCardDao">

    <select id="findByCardId" resultType="com.xiaotiyun.school.manager.model.entity.DeviceCardEntity">
        SELECT * FROM device_card_student WHERE card_id = #{cardId} AND deleted = 0
    </select>

    <select id="findByStudentId" resultType="com.xiaotiyun.school.manager.model.entity.DeviceCardEntity">
        SELECT * FROM device_card_student WHERE student_id = #{studentId} AND deleted = 0
    </select>

    <select id="findByDeviceSn" resultType="com.xiaotiyun.school.manager.model.entity.DeviceCardEntity">
        SELECT * FROM device_card_student WHERE device_sn = #{deviceSn} AND deleted = 0
    </select>

</mapper>
