<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaotiyun.school.manager.dao.DeviceFaceDao">

    <select id="findByStudentId" resultType="com.xiaotiyun.school.manager.model.entity.DeviceFaceEntity">
        SELECT * FROM device_face WHERE student_id = #{studentId} AND deleted = 0
    </select>

    <select id="findByDeviceSn" resultType="com.xiaotiyun.school.manager.model.entity.DeviceFaceEntity">
        SELECT * FROM device_face WHERE device_sn = #{deviceSn} AND deleted = 0
    </select>

</mapper>
