<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaotiyun.school.manager.dao.GradeRecordClassSettingDao">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.xiaotiyun.school.manager.model.entity.GradeRecordClassSettingEntity">
        <id column="id" property="id"/>
        <result column="school_id" property="schoolId"/>
        <result column="school_year" property="schoolYear"/>
        <result column="class_id" property="classId"/>
        <result column="grade_id" property="gradeId"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, school_id, school_year, class_id, create_time, update_time, deleted
    </sql>

    <select id="selectValidClassSettings" resultType="com.xiaotiyun.school.manager.model.entity.GradeRecordClassSettingEntity">
        SELECT 
            s.*
        FROM grade_record_class_setting s
        INNER JOIN sys_class c ON s.class_id = c.id 
        WHERE s.school_id = #{schoolId}
        AND s.school_year = #{schoolYear}
        AND s.deleted = 0
        AND c.deleted = 0
        ORDER BY s.id ASC
    </select>

</mapper> 