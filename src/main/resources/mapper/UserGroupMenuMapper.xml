<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaotiyun.school.manager.dao.UserGroupMenuDao">
    <insert id="insertBatch">
        INSERT INTO sys_user_group_menu(user_group_id, menu_id, create_time, update_time)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.userGroupId}, #{item.menuId}, NOW(), NOW())
        </foreach>
    </insert>
</mapper> 