<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.xiaotiyun.school.manager.dao.StudentQualityScoreDao">

    <select id="getStudentQualityScoreList"
            resultType="com.xiaotiyun.school.manager.model.entity.StudentQualityScore">
        select *
        from student_quality_score
        where deleted = 0 and schoolId = #{schoolId}
        <if test="sid != null">
            and sid = #{sid}
        </if>
        <if test="term != null">
            and term = #{term}
        </if>
        <if test="classId != null">
            and class_id = #{classId}
        </if>
        group by student_id
    </select>
</mapper>