<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaotiyun.school.manager.dao.GradeGroupMapper">


    <sql id="Base_Column_List">
        id,department,grade_group_name,
        school_id,create_time,update_time,
        deleted
    </sql>
    <select id="getGradeGroupMapBySchoolId" resultType="com.xiaotiyun.school.manager.model.entity.GradeGroup">
        SELECT
            *
        FROM grade_group
        WHERE school_id = #{schoolId}
          AND deleted = 0
    </select>
</mapper>
